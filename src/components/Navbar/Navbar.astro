---
import styles from "./Navbar.module.css";

export interface Props {
  brand?: string;
  labels?: Partial<{
    service: string;
    product: string;
    about: string;
    contact: string;
    webLab: string;
    openSourceIntegrator: string;
  }>;
  lang?: "hr" | "en";
  currentPath?: string;
}
const {
  brand = "Bitelex",
  labels,
  lang = "hr",
  currentPath,
}: Props = Astro.props;

const navLabels = {
  service: "Service",
  product: "Product",
  about: "About",
  contact: "Contact",
  webLab: "Web Lab",
  openSourceIntegrator: "Open Source Integrator",
  ...labels,
};

type LabelKey = keyof typeof navLabels;
type NavChildItem = {
  label: LabelKey;
  href: string;
};
type NavItem = {
  label: LabelKey;
  href: string;
  children?: NavChildItem[];
};

const navItems: NavItem[] = [
  {
    label: "service",
    href: lang ? `/${lang}/#service` : "/#service",
    children: [
      {
        label: "webLab",
        href: lang ? `/${lang}/web-lab` : "/web-lab",
      },
      {
        label: "openSourceIntegrator",
        href: lang
          ? `/${lang}/open-source-integrator`
          : "/open-source-integrator",
      },
    ],
  },
  {
    label: "product",
    href: lang ? `/${lang}/#product` : "/#product",
  },
  {
    label: "about",
    href: lang ? `/${lang}/about` : "/about",
  },
  {
    label: "contact",
    href: lang ? `/${lang}/contact` : "/contact",
  },
];

const effectivePath = currentPath ?? Astro.url?.pathname;

const getLangHref = (targetLang: "hr" | "en") => {
  if (!effectivePath) return `/${targetLang}/`;
  const match = effectivePath.match(/^\/(hr|en)(\/.*)?$/);
  if (!match) return `/${targetLang}/`;
  const rest = match[2] ?? "/";
  return `/${targetLang}${rest}`;
};

const hrHref = getLangHref("hr");
const enHref = getLangHref("en");
---

<nav id="site-nav" class={styles["site-nav"]} aria-label="Main navigation">
  <div class={styles["site-nav__inner"]}>
    <!-- Brand -->
    <a
      href={lang ? `/${lang}/` : "/"}
      class={styles["site-nav__brand"]}
      aria-label={brand}
    >
      <img
        src="/logo_svg.png"
        alt=""
        width="52"
        height="52"
        aria-hidden="true"
        class={styles["brand-logo"]}
      />

      <span class={styles["brand-bracket"]}>&lt;</span>
      <span class={styles["brand-name"]}>{brand}</span>
      <span class={styles["brand-bracket"]}>/&gt;</span>
    </a>

    <!-- Desktop links -->
    <ul class={styles["site-nav__links"]} role="list">
      {
        navItems.map((item) => (
          <li class={item.children ? styles["nav-dropdown"] : undefined}>
            <a
              href={item.href}
              class={`${styles["site-nav__link"]} ${item.children ? styles["nav-dropdown__trigger"] : ""}`}
              aria-haspopup={item.children ? "true" : undefined}
            >
              <span class="link-label">{navLabels[item.label]}</span>
              {item.children && (
                <span class={styles["nav-dropdown__caret"]} aria-hidden="true">
                  ▾
                </span>
              )}
            </a>

            {item.children && (
              <ul class={styles["nav-dropdown__menu"]} role="list">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} class={styles["nav-dropdown__item"]}>
                      {navLabels[child.label]}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>

    <!-- Lang + mobile toggle -->
    <div class={styles["site-nav__right"]}>
      <!-- Language switcher -->
      <div class={styles["lang-switch"]} role="group" aria-label="Language">
        <a
          href={hrHref}
          class={`${styles["lang-btn"]} ${lang === "hr" ? styles["lang-btn--active"] : ""}`}
          aria-current={lang === "hr" ? "true" : undefined}
          title="Hrvatski"
        >
          HR
        </a>
        <span class={styles["lang-sep"]}>/</span>
        <a
          href={enHref}
          class={`${styles["lang-btn"]} ${lang === "en" ? styles["lang-btn--active"] : ""}`}
          aria-current={lang === "en" ? "true" : undefined}
          title="English"
        >
          EN
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        class={styles["site-nav__toggle"]}
        aria-controls="mobile-menu"
        aria-expanded="false"
        id="nav-toggle"
        aria-label="Open main menu"
      >
        <span class={styles["toggle-bar"]}></span>
        <span class={styles["toggle-bar"]}></span>
        <span class={styles["toggle-bar"]}></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class={styles["site-nav__mobile"]} aria-hidden="true">
    <ul role="list">
      {
        navItems.map((item) => (
          <li>
            <a href={item.href} class={styles["mobile-link"]}>
              {navLabels[item.label]}
            </a>

            {item.children && (
              <ul class={styles["mobile-submenu"]} role="list">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} class={styles["mobile-submenu__link"]}>
                      {navLabels[child.label]}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>

    <div class={styles["mobile-lang"]}>
      <a
        href={hrHref}
        class={`${styles["lang-btn"]} ${lang === "hr" ? styles["lang-btn--active"] : ""}`}
        title="Hrvatski"
      >
        HR
      </a>
      <span class={styles["lang-sep"]}>/</span>
      <a
        href={enHref}
        class={`${styles["lang-btn"]} ${lang === "en" ? styles["lang-btn--active"] : ""}`}
        title="English"
      >
        EN
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("site-nav");
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  const SCROLL_THRESHOLD = 200;
  const HOME_SCROLL_KEY = "home-scroll-target";

  const scrollToHashTarget = (hash: string) => {
    if (!hash || hash.length < 2) return;
    const target = document.querySelector(hash);
    if (!target) return;
    target.scrollIntoView({ behavior: "smooth", block: "start" });
  };

  const consumePendingHomeScroll = () => {
    const pendingHash = sessionStorage.getItem(HOME_SCROLL_KEY);
    if (!pendingHash) return;
    sessionStorage.removeItem(HOME_SCROLL_KEY);
    // Wait one frame so layout/sections are ready before scrolling.
    requestAnimationFrame(() => scrollToHashTarget(pendingHash));
  };

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      menu.setAttribute("aria-hidden", String(isOpen));
      menu.classList.toggle("site-nav__mobile--open", !isOpen);
    });
  }

  const navHashLinks = document.querySelectorAll('#site-nav a[href*="/#"]');
  navHashLinks.forEach((link) => {
    if (!(link instanceof HTMLAnchorElement)) return;
    link.addEventListener("click", () => {
      const href = link.getAttribute("href");
      if (!href) return;
      const url = new URL(href, window.location.origin);
      if (!url.hash) return;

      const navigatingAcrossPages = url.pathname !== window.location.pathname;
      if (navigatingAcrossPages) {
        sessionStorage.setItem(HOME_SCROLL_KEY, url.hash);
      }
    });
  });

  if (window.location.hash) {
    requestAnimationFrame(() => scrollToHashTarget(window.location.hash));
  }
  consumePendingHomeScroll();

  if (nav) {
    const getDocumentScrollTop = () => {
      const scrollElement = document.scrollingElement;
      const scrollTop =
        window.scrollY ||
        window.pageYOffset ||
        scrollElement?.scrollTop ||
        document.documentElement.scrollTop ||
        document.body.scrollTop ||
        0;

      if (scrollTop) return scrollTop;
      const bodyTop = document.body?.getBoundingClientRect?.().top ?? 0;
      return Math.abs(bodyTop);
    };

    const updateNav = (event?: Event) => {
      const target = event?.target;
      const targetScrollTop =
        target instanceof HTMLElement ? target.scrollTop : 0;
      const scrollTop = targetScrollTop || getDocumentScrollTop();
      const isScrolled = scrollTop >= SCROLL_THRESHOLD;
      nav.dataset.scrolled = isScrolled ? "true" : "false";
    };

    updateNav();
    window.addEventListener("scroll", updateNav, { passive: true });
    window.addEventListener("resize", updateNav, { passive: true });
    document.addEventListener("scroll", updateNav, {
      passive: true,
      capture: true,
    });
  }
</script>
