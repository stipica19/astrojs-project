---
import featureStyles from "../FeatureSection/FeatureSection.module.css";
import styles from "./WebLab.module.css";

interface Props {
  locations: string[];
  ariaLabel: string;
}

const { locations, ariaLabel }: Props = Astro.props;

const points = [
  { x: 505, y: 130 },
  { x: 210, y: 120 },
  { x: 520, y: 165 },
  { x: 540, y: 185 },
];

const labeledPoints = points.map((point, idx) => ({
  ...point,
  label: locations[idx] ?? "",
}));
---

<div
  class={`${featureStyles["feature-card"]} ${styles["map-card"]} rounded-xl p-6`}
>
  <svg
    class={styles["map-svg"]}
    viewBox="0 0 900 420"
    role="img"
    aria-label={ariaLabel}
  >
    <rect x="20" y="20" width="860" height="380" rx="18" fill="none"></rect>
    <path
      class={styles["map-grid"]}
      d="M100 80H800 M100 200H800 M100 320H800 M180 60V360 M360 60V360 M540 60V360 M720 60V360"
      fill="none"></path>
    <path
      class={styles["map-land"]}
      d="M120 130 C160 90, 240 90, 280 130 C300 150, 300 190, 270 210 C230 235, 185 230, 150 210 C120 190, 110 160, 120 130 Z"
    ></path>
    <path
      class={styles["map-land"]}
      d="M320 150 C370 110, 460 115, 500 150 C540 185, 530 240, 480 260 C430 280, 360 270, 330 235 C305 210, 300 175, 320 150 Z"
    ></path>
    <path
      class={styles["map-land"]}
      d="M560 120 C610 90, 690 95, 730 120 C760 140, 770 175, 750 205 C720 245, 640 260, 590 235 C555 215, 540 150, 560 120 Z"
    ></path>
    <path
      class={styles["map-land"]}
      d="M610 260 C660 240, 730 245, 760 270 C780 290, 775 320, 740 340 C700 360, 640 355, 610 330 C585 310, 585 280, 610 260 Z"
    ></path>

    {
      labeledPoints.map((point) => (
        <g>
          <circle class={styles["map-dot"]} cx={point.x} cy={point.y} r="7" />
          <text class={styles["map-label"]} x={point.x + 12} y={point.y + 4}>
            {point.label}
          </text>
        </g>
      ))
    }
  </svg>

  <div class={styles.locations}>
    {locations.map((location) => <div>• {location}</div>)}
  </div>
</div>
