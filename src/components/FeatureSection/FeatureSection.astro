---
import FeatureCards from "./FeatureCards.astro";
import FeatureRows from "./FeatureRows.astro";
import styles from "./FeatureSection.module.css";

interface FeatureItem {
  icon?: any;
  title: string;
  desc: string;
  href?: string;
}

interface Props {
  title?: string;
  items?: FeatureItem[];
  dark?: boolean;
  highlightIndex?: number;
  id?: string;
  variant?: "cards" | "rows";
  ctaLabel?: string;
}

const {
  title = "Our mission",
  items = [] as FeatureItem[],
  dark = false,
  highlightIndex = -1,
  id = "features",
  variant = "cards",
  ctaLabel = "Learn More",
}: Props = Astro.props;
---

{
  variant === "rows" ? (
    <FeatureRows title={title} items={items} ctaLabel={ctaLabel} id={id} />
  ) : (
    <FeatureCards
      title={title}
      items={items}
      dark={dark}
      highlightIndex={highlightIndex}
      id={id}
    />
  )
}

<script src="../../lib/feature-gsap.ts"></script>
