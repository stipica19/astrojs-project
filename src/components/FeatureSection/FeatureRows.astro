---
import styles from "./FeatureSection.module.css";

interface FeatureItem {
  title: string;
  desc: string;
  href?: string;
}

interface Props {
  title: string;
  items: FeatureItem[];
  ctaLabel: string;
  id: string;
}

const { title, items, ctaLabel, id }: Props = Astro.props;
---

<style>
  @keyframes glow-pulse {
    0%,
    100% {
      filter: drop-shadow(0 0 4px #3b82f6);
    }
    50% {
      filter: drop-shadow(0 0 14px #3b82f6) drop-shadow(0 0 28px #60a5fa);
    }
  }

  @keyframes dash-flow {
    to {
      stroke-dashoffset: -40;
    }
  }

  @keyframes spin-slow {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes float-y {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes blink-cursor {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  /* --- ikona 1: cip --- */
  .icon-chip {
    animation: glow-pulse 2.5s ease-in-out infinite;
  }
  .icon-chip .pin-line {
    stroke-dasharray: 20 5;
    animation: dash-flow 1.4s linear infinite;
  }

  /* --- ikona 2: mreza --- */
  .icon-net {
    animation: glow-pulse 2.5s ease-in-out infinite 0.6s;
  }
  .icon-net .ring-outer {
    transform-origin: 100px 100px;
    animation: spin-slow 12s linear infinite;
  }
  .icon-net .ring-mid {
    transform-origin: 100px 100px;
    animation: spin-slow 8s linear infinite reverse;
  }

  /* --- ikona 3: browser --- */
  .icon-browser {
    animation: glow-pulse 2.5s ease-in-out infinite 1.2s;
  }
  .icon-browser .mobile-device {
    animation: float-y 3s ease-in-out infinite;
  }
  .icon-browser .cursor-blink {
    animation: blink-cursor 1.1s step-end infinite;
  }
</style>

<section
  class={`${styles["feature-rows"]} feature-rows relative overflow-hidden px-4 py-20 md:px-6`}
  id={id}
>
