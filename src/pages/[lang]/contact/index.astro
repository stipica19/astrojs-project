---
import Layout from "@/layouts/Layout.astro";
import { getT } from "@/i18n";
import KontaktForm from "@/components/Kontakt/KontaktForm.astro";

export const prerender = true;

export async function getStaticPaths() {
  const langs = ["hr", "en"] as const;
  return langs.map((lang) => ({
    params: { lang },
    props: { lang, t: getT(lang) },
  }));
}

interface PageProps {
  lang: "hr" | "en";
  t: any;
}
const pageProps = Astro.props as Partial<PageProps> | undefined;
const lang = pageProps?.lang ?? (Astro.params?.lang as "hr" | "en") ?? "hr";
const t = pageProps?.t ?? getT(lang);
const c = t.contact;
---

<Layout
  brand={t.navbar.brand}
  labels={t.navbar}
>
  <div class="page-bg" aria-hidden="true">
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <main class="contact-page">
    <div class="mx-auto max-w-4xl px-4 md:px-6 py-28">
      <header class="contact-hero">
        <h1 class="contact-title">{c.title}</h1>
        <p class="contact-lead">{c.lead}</p>
      </header>
      <KontaktForm />
    </div>
  </main>
</Layout>
