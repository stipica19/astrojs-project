---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero/Hero.astro";
import FeatureSection from "@/components/FeatureSection/FeatureSection.astro";
import BuildWebsiteSectin from "@/components/BuildWebsiteSection/BuildWebsiteSection.astro";
import PortfolioSection from "@/components/PortfolioSection/PortfolioSection.astro";
import { getT } from "@/i18n";
import Divider from "@/components/divider/divider.astro";
import TechSlider from "@/components/TechSlider/TechSlider.astro";

export const prerender = true;

export async function getStaticPaths() {
  const langs = ["hr", "en"];
  return langs.map((lang) => ({
    params: { lang },
    props: { lang, t: getT(lang as "hr" | "en") },
  }));
}

interface PageProps {
  lang: "hr" | "en";
  t: any;
}
const pageProps = Astro.props as Partial<PageProps> | undefined;
const lang = pageProps?.lang ?? (Astro.params?.lang as "hr" | "en") ?? "hr";
const t = pageProps?.t ?? getT(lang);

const withLangPrefix = (href?: string) => {
  if (!href) return "#";
  if (/^https?:\/\//.test(href)) return href; // eksterni link
  return href.startsWith(`/${lang}/`)
    ? href
    : `/${lang}${href.startsWith("/") ? href : `/${href}`}`;
};

const serviceItems = t.sections.services.items.map((item: any) => ({
  ...item,
  href: withLangPrefix(item.href),
}));
---

<Layout
  brand={t.navbar.brand}
  labels={{
    service: t.navbar.service,
    product: t.navbar.product,
    about: t.navbar.about,
    contact: t.navbar.contact,
    webLab: t.navbar.webLab,
  }}
>
  <div class="page-bg" aria-hidden="true">
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>
  <Hero
    badge={t.hero.badge}
    headline={t.hero.headline}
    kicker={t.hero.sub.kicker}
    description={t.hero.sub.text}
    statsLabels={t.hero.stats}
    ctaExplore={t.hero.ctaExplore}
    ctaView={t.hero.ctaView}
    lang={lang}
  />
  <Divider />
  <main class="mx-auto px-0 md:px-0">
    <FeatureSection
      id="service"
      title={t.sections.services.title}
      variant="cards"
      ctaLabel={t.common.learnMore}
      highlightIndex={1}
      items={serviceItems}
    />
    <BuildWebsiteSectin lang={lang} />
    <FeatureSection
      id="our-mission"
      title={t.sections.mission.title}
      dark={false}
      highlightIndex={1}
      items={t.sections.mission.items}
    />
    <Divider />
    <FeatureSection
      id="product"
      title={t.sections.products.title}
      dark={false}
      highlightIndex={1}
      items={t.sections.products.items}
    />
    <Divider />
    <PortfolioSection lang={lang} />
    <!-- <TechSlider /> -->
  </main>
</Layout>
