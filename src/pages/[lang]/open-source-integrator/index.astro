---
import Layout from "@/layouts/Layout.astro";
import Divider from "@/components/divider/divider.astro";
import FeatureCards from "@/components/FeatureSection/FeatureCards.astro";
import WebLabPortfolioGrid from "@/components/WebLab/WebLabPortfolioGrid.astro";
import styles from "@/components/WebLab/WebLab.module.css";
import { getT } from "@/i18n";
import KontaktForm from "@/components/Kontakt/KontaktForm.astro";
import { Network, Server, ShieldCheck, Repeat, Wrench } from "@lucide/astro";

export const prerender = true;

export async function getStaticPaths() {
  const langs = ["hr", "en"] as const;
  return langs.map((lang) => ({
    params: { lang },
    props: { lang, t: getT(lang) },
  }));
}

interface PageProps {
  lang: "hr" | "en";
  t: any;
}

const pageProps = Astro.props as Partial<PageProps> | undefined;
const lang = pageProps?.lang ?? (Astro.params?.lang as "hr" | "en") ?? "hr";
const t = pageProps?.t ?? getT(lang);
const c = t.openSourceIntegrator;
const openSourceServiceIcons = [Network, Server, ShieldCheck, Repeat, Wrench];
const withIcons = (items: any[], icons: any[]) =>
  items.map((item, idx) => ({ ...item, icon: icons[idx] }));
---

<Layout
  brand={t.navbar.brand}
  labels={t.navbar}
  title={c.hero.title}
  description={c.hero.seoDescription}
>
  <div class="page-bg" aria-hidden="true">
    <div class="grid-bg"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <main class="mx-auto px-0 md:px-0">
    <section class="px-4 py-20 md:px-6">
      <div class="mx-auto max-w-7xl">
        <div
          class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between"
        >
          <div class="max-w-3xl">
            <h1
              class={`text-4xl font-bold text-white md:text-5xl ${styles["outline-word"]}`}
            >
              {c.hero.title}
            </h1>
            <p class={`${styles["section-lead"]} mt-4`}>
              {c.hero.description}
            </p>
          </div>
        </div>
      </div>
    </section>

    <Divider />

    <FeatureCards
      id="open-source-services"
      title={c.services.title}
      dark={false}
      highlightIndex={1}
      items={withIcons(c.services.items, openSourceServiceIcons)}
    />

    <Divider />

    <section class="px-4 py-16 md:px-6" id="open-source-tools">
      <div class="mx-auto max-w-7xl">
        <h2 class="text-3xl font-bold text-white md:text-4xl">
          {c.tools.title}
        </h2>
        <p class={`${styles["section-lead"]} ${styles["lead-inter"]} mt-4`}>
          {c.tools.description}
        </p>
        <div class="mt-8">
          <WebLabPortfolioGrid items={c.tools.items} ctaLabel={c.tools.cta} />
        </div>
      </div>
    </section>

    <Divider />

    <section class="px-4 py-16 md:px-6" id="open-source-pricing">
      <div class="mx-auto max-w-7xl">
        <h2 class="text-3xl font-bold text-white md:text-4xl">
          {c.pricing.title}
        </h2>
        <p class={`${styles["section-lead"]} ${styles["lead-inter"]} mt-4`}>
          {c.pricing.description}
        </p>
      </div>
    </section>

    <Divider />
    <section class="px-4 py-16 md:px-6" id="open-source-contact">
      <div class="mx-auto max-w-5xl">
        <KontaktForm />
      </div>
    </section>
  </main>
</Layout>
